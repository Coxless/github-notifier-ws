{
  "$schema": "https://schema.tauri.app/config/2.json",
  "productName": "github-notifier-ws",
  "version": "0.1.0",
  "identifier": "dev.coxless.github-notifier-ws",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "github-notifier-ws",
        "width": 1,
        "height": 1,
        "visible": false,
        "skipTaskbar": true,
        "closable": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Japanese", "English"],
        "installMode": "perMachine",
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["github-notifier-ws"]
      }
    }
  }
}
